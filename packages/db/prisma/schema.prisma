generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  BRANCH_MANAGER
  STAFF
  VIEWER
}

enum BaseUnit {
  GRAM
  KILOGRAM
  MILLILITER
  LITER
  PIECE
}

enum StockMovementType {
  PURCHASE
  PRODUCTION_CONSUMPTION
  MANUAL_ADJUSTMENT
  WASTE
  RETURN
}

enum PurchaseStatus {
  ACTIVE
  CANCELLED
}

enum ProductionStatus {
  ACTIVE
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  ACTIVATE
  STATUS_CHANGE
  STOCK_ADJUSTMENT
  LOGIN
  LOGOUT
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  isActive         Boolean   @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memberships   OrganizationMember[]
  branchMembers BranchMember[]
  auditLogs     AuditLog[]

  @@index([createdAt])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganizationMember[]
  branches       Branch[]
  suppliers      Supplier[]
  ingredients    Ingredient[]
  products       Product[]
  recipes        Recipe[]
  purchases      Purchase[]
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  productions    Production[]
  customers      Customer[]
  orders         Order[]
  branchMembers  BranchMember[]
  auditLogs      AuditLog[]

  @@index([createdAt])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchases      Purchase[]
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  productions    Production[]
  orders         Order[]
  members        BranchMember[]
  auditLogs      AuditLog[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model BranchMember {
  id             String   @id @default(cuid())
  branchId       String
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([branchId, userId])
  @@index([organizationId])
  @@index([branchId])
  @@index([userId])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  phone          String?
  email          String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchases    Purchase[]

  @@index([organizationId])
  @@index([createdAt])
}

model Ingredient {
  id                 String    @id @default(cuid())
  organizationId     String
  name               String
  sku                String
  baseUnit           BaseUnit
  minimumStockLevel  Decimal?  @db.Decimal(18, 6)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipeItems    RecipeItem[]
  purchaseItems  PurchaseItem[]
  stockBatches   StockBatch[]
  stockMovements StockMovement[]

  @@unique([organizationId, sku])
  @@unique([organizationId, name])
  @@index([organizationId])
}

model Product {
  id                   String   @id @default(cuid())
  organizationId       String
  name                 String
  sku                  String
  description          String?
  defaultServingCount  Int      @default(1)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipes      Recipe[]
  productions  Production[]
  orderItems   OrderItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model Recipe {
  id             String   @id @default(cuid())
  organizationId String
  productId      String
  name           String
  yieldQuantity  Decimal  @db.Decimal(18, 6)
  yieldUnit      BaseUnit
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  items        RecipeItem[]
  productions  Production[]

  @@index([organizationId])
  @@index([productId])
}

model RecipeItem {
  id           String   @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal  @db.Decimal(18, 6)
  unit         BaseUnit
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

model Purchase {
  id                 String         @id @default(cuid())
  organizationId       String
  branchId           String
  supplierId         String?
  purchasedAt        DateTime
  invoiceNumber      String?
  notes              String?
  status             PurchaseStatus @default(ACTIVE)
  cancelledAt        DateTime?
  cancelledByUserId  String?
  cancellationReason String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier     Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items        PurchaseItem[]

  @@index([organizationId])
  @@index([branchId])
  @@index([supplierId])
  @@index([purchasedAt])
  @@index([status])
}

model PurchaseItem {
  id           String   @id @default(cuid())
  purchaseId   String
  ingredientId String
  quantity     Decimal  @db.Decimal(18, 6)
  unit         BaseUnit
  totalPrice   Decimal  @db.Decimal(18, 6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchase   Purchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  stockBatch StockBatch?

  @@index([purchaseId])
  @@index([ingredientId])
}

model StockBatch {
  id                String   @id @default(cuid())
  organizationId    String
  branchId          String
  ingredientId      String
  purchaseItemId    String?  @unique
  initialQuantity   Decimal  @db.Decimal(18, 6)
  remainingQuantity Decimal  @db.Decimal(18, 6)
  unit              BaseUnit
  unitCost          Decimal  @db.Decimal(18, 6)
  receivedAt        DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredient     Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  purchaseItem   PurchaseItem?   @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@index([organizationId])
  @@index([branchId])
  @@index([ingredientId])
  @@index([receivedAt])
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String
  branchId       String
  ingredientId   String
  stockBatchId   String?
  productionId   String?
  type           StockMovementType
  quantity       Decimal           @db.Decimal(18, 6)
  unit           BaseUnit
  reason         String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  stockBatch   StockBatch?  @relation(fields: [stockBatchId], references: [id], onDelete: SetNull)
  production   Production?  @relation(fields: [productionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([branchId])
  @@index([ingredientId])
  @@index([stockBatchId])
  @@index([productionId])
  @@index([createdAt])
}

model Production {
  id                 String           @id @default(cuid())
  organizationId     String
  branchId           String
  productId          String
  recipeId           String
  quantityProduced   Decimal          @db.Decimal(18, 6)
  totalCostSnapshot  Decimal          @db.Decimal(18, 6)
  unitCostSnapshot   Decimal          @db.Decimal(18, 6)
  producedAt         DateTime
  notes              String?
  status             ProductionStatus @default(ACTIVE)
  cancelledAt        DateTime?
  cancelledByUserId  String?
  cancellationReason String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe         Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@index([organizationId])
  @@index([branchId])
  @@index([productId])
  @@index([producedAt])
  @@index([status])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  email          String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([organizationId])
  @@index([createdAt])
}

model Order {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String
  customerId     String?
  orderNumber    String
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @db.Decimal(18, 6)
  orderedAt      DateTime    @default(now())
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([branchId])
  @@index([customerId])
  @@index([orderedAt])
  @@index([createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Decimal  @db.Decimal(18, 6)
  unitPrice  Decimal  @db.Decimal(18, 6)
  totalPrice Decimal  @db.Decimal(18, 6)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  actorUserId    String?
  actorEmail     String?
  action         AuditAction
  entityType     String
  entityId       String?
  entityLabel    String?
  branchId       String?
  before         Json?
  after          Json?
  metadata       Json?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType])
  @@index([organizationId, actorUserId])
  @@index([organizationId, action])
  @@index([organizationId, branchId])
}
